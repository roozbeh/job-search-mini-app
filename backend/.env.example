# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/jobsearch?retryWrites=true&w=majority
MONGODB_DB=jobsearch

# AgnicPay API endpoints (defaults are correct — only change if AgnicPay updates their URLs)
AGNIC_LLM_BASE=https://api.agnic.ai/v1
AGNIC_JOB_SEARCH_BASE=https://api.agnic.ai/v1/custom/job-search
AGNIC_FETCH_PROXY=https://api.agnic.ai/api/x402/fetch

PORT=8000

# Job search provider: "serpapi" | "agnic"
JOB_SEARCH_PROVIDER=serpapi

# Keys for each provider (only the active one needs to be set)
SERPAPI_KEY=
